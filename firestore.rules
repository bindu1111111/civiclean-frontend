// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: reports
// Document ID: auto-generated
// Fields:
//   - userId: string (required) - UID of the reporter
//   - location: map (required) - { lat: number, lng: number, address: string }
//   - imageUrl: string (required) - URL to the image
//   - analysis: map (required) - AI analysis results
//   - timestamp: number (required) - Creation time
//   - status: string (required) - ['pending', 'verified', 'cleaned']
//
// Collection: riskZones
// Document ID: auto-generated
// Fields:
//   - lat: number (required)
//   - lng: number (required)
//   - riskLevel: number (required) - 0-100
//   - prediction: string (required)
//   - lastUpdated: number (required)
//
// Collection: users
// Document ID: userId
// Fields:
//   - displayName: string (required)
//   - points: number (required)
//   - reportsCount: number (required)
//   - rank: string (required)
//   - role: string (optional) - ['admin', 'user']
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "rharshitha179@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUrl(url) {
      return url is string && (
        url.matches("^https://.*") || 
        url.matches("^http://.*") || 
        (url.size() > 11 && url[0:11] == "data:image/")
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidReport(data) {
      return hasRequiredFields(['userId', 'location', 'imageUrl', 'analysis', 'timestamp', 'status']) &&
             data.userId == request.auth.uid &&
             data.location.lat is number && data.location.lng is number &&
             isValidUrl(data.imageUrl) &&
             data.analysis.garbage_detected is bool &&
             data.timestamp is number &&
             data.status in ['pending', 'verified', 'cleaned'];
    }

    function isValidUser(data) {
      return hasRequiredFields(['displayName', 'points', 'reportsCount', 'rank']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.points is number && data.points >= 0 &&
             data.reportsCount is number && data.reportsCount >= 0 &&
             data.rank is string;
    }

    function isValidRiskZone(data) {
      return hasRequiredFields(['lat', 'lng', 'riskLevel', 'prediction', 'lastUpdated']) &&
             data.lat is number && data.lng is number &&
             data.riskLevel is number && data.riskLevel >= 0 && data.riskLevel <= 100 &&
             data.prediction is string && data.prediction.size() < 500 &&
             data.lastUpdated is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReport(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin()) && isValidReport(request.resource.data);
      allow delete: if isAdmin();
    }

    match /riskZones/{zoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (isOwner(userId) ? request.resource.data.role == resource.data.role : true);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
